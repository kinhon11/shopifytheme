{
  "sections": {
    "hero": {
      "type": "hero",
      "blocks": {
        "text": {
          "type": "text",
          "settings": {
            "text": "<h2>La nuova generazione della bellezza</h2><p>Cosmetici 100% naturali, ecosostenibili e made in Italy per la cura della tua pelle.</p>",
            "type_preset": "rte",
            "alignment": "center",
            "color": "var(--color-foreground-heading)"
          }
        },
        "button": {
          "type": "button",
          "settings": {
            "label": "SCOPRI I PRODOTTI",
            "link": "shopify://collections/all",
            "style_class": "button-primary"
          }
        }
      },
      "block_order": [
        "text",
        "button"
      ],
      "settings": {
        "color_scheme": "scheme-2",
        "padding-block-start": 100,
        "padding-block-end": 100
      }
    },
    "trust_badges": {
      "type": "multicolumn",
      "blocks": {
        "badge_1": {
          "type": "column",
          "settings": {
            "title": "100% Naturale",
            "text": "<p>Formulazioni pure e sicure</p>"
          }
        },
        "badge_2": {
          "type": "column",
          "settings": {
            "title": "Cruelty Free",
            "text": "<p>Non testato sugli animali</p>"
          }
        },
        "badge_3": {
          "type": "column",
          "settings": {
            "title": "Made in Italy",
            "text": "<p>Produzione locale controllata</p>"
          }
        },
        "badge_4": {
          "type": "column",
          "settings": {
            "title": "Pack Sostenibile",
            "text": "<p>Rispetto per l'ambiente</p>"
          }
        }
      },
      "block_order": [
        "badge_1",
        "badge_2",
        "badge_3",
        "badge_4"
      ],
      "settings": {
        "title": "",
        "columns_desktop": 4,
        "column_alignment": "center",
        "background_style": "none",
        "color_scheme": "scheme-1",
        "padding-block-start": 40,
        "padding-block-end": 40
      }
    },
    "bestsellers": {
      "type": "product-list",
      "blocks": {
        "static-header": {
          "type": "_product-list-content",
          "static": true,
          "settings": {
            "horizontal_alignment_flex_direction_column": "center"
          },
          "blocks": {
            "title": {
              "type": "_product-list-text",
              "settings": {
                "text": "<h2>I Nostri Bestseller</h2>",
                "type_preset": "h2",
                "alignment": "center"
              }
            }
          },
          "block_order": [
            "title"
          ]
        },
        "static-product-card": {
          "type": "_product-card",
          "static": true,
          "settings": {
            "border": "none",
            "border_radius": 8
          },
          "blocks": {
            "gallery": {
              "type": "_product-card-gallery",
              "settings": {}
            },
            "title": {
              "type": "product-title",
              "settings": {
                "alignment": "center"
              }
            },
            "price": {
              "type": "price",
              "settings": {
                "alignment": "center"
              }
            },
            "add_to_cart": {
              "type": "add-to-cart-button",
              "settings": {
                "width": "fill"
              }
            }
          },
          "block_order": [
            "gallery",
            "title",
            "price",
            "add_to_cart"
          ]
        }
      },
      "settings": {
        "collection": "all",
        "layout_type": "grid",
        "columns": 4,
        "padding-block-start": 60,
        "padding-block-end": 60
      }
    },
    "categories": {
      "type": "multicolumn",
      "blocks": {
        "cat_1": {
          "type": "column",
          "settings": {
            "title": "Viso"
          }
        },
        "cat_2": {
          "type": "column",
          "settings": {
            "title": "Corpo"
          }
        },
        "cat_3": {
          "type": "column",
          "settings": {
            "title": "Capelli"
          }
        },
        "cat_4": {
          "type": "column",
          "settings": {
            "title": "Kit Risparmio"
          }
        }
      },
      "block_order": [
        "cat_1",
        "cat_2",
        "cat_3",
        "cat_4"
      ],
      "settings": {
        "title": "Esplora per Categoria",
        "heading_size": "h2",
        "column_alignment": "center",
        "background_style": "none",
        "padding-block-start": 60,
        "padding-block-end": 60
      }
    },
    "brand_story": {
      "type": "image-with-text",
      "blocks": {
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "Perché sceglierci?"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "<p>Siamo nati per offrire formulazioni efficaci e rispettose dell'ambiente. I nostri prodotti sono creati con ingredienti puri, pensati per valorizzare la tua bellezza naturale.</p>"
          }
        },
        "button": {
          "type": "button",
          "settings": {
            "label": "LA NOSTRA FILOSOFIA",
            "link": "/"
          }
        }
      },
      "block_order": [
        "heading",
        "text",
        "button"
      ],
      "settings": {
        "layout": "image_first",
        "desktop_content_position": "middle",
        "padding-block-start": 80,
        "padding-block-end": 80
      }
    }
  },
  "order": [
    "hero",
    "trust_badges",
    "bestsellers",
    "categories",
    "brand_story"
  ]
}