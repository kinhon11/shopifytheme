{
  "sections": {
    "hero": {
      "type": "hero",
      "blocks": {
        "text": {
          "type": "text",
          "settings": {
            "text": "<h2>Benvenuti su Xophia</h2><p>Il negozio online per il tuo stile di vita europeo moderno. Scorri per scoprire i nostri prodotti.</p>",
            "type_preset": "rte",
            "alignment": "center",
            "color": "var(--color-foreground-heading)"
          }
        },
        "button": {
          "type": "button",
          "settings": {
            "label": "Acquista Ora",
            "link": "shopify://collections/all",
            "style_class": "button-primary"
          }
        }
      },
      "block_order": [
        "text",
        "button"
      ],
      "settings": {
        "color_scheme": "scheme-1",
        "horizontal_alignment_flex_direction_column": "center",
        "vertical_alignment_flex_direction_column": "center",
        "padding-block-start": 80,
        "padding-block-end": 80
      }
    },
