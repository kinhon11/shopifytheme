{
  "type": "footer",
  "name": "Footer",
  "sections": {
    "footer_main": {
      "type": "footer",
      "blocks": {
        "col1_newsletter": {
          "type": "group",
          "settings": {
            "content_direction": "column",
            "vertical_on_mobile": true,
            "horizontal_alignment": "flex-start",
            "vertical_alignment": "center",
            "gap": 16,
            "width": "fill",
            "inherit_color_scheme": false,
            "color_scheme": "scheme-4",
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {
            "newsletter_heading": {
              "type": "text",
              "settings": {
                "text": "<h2>Join our mailing list</h2>",
                "width": "100%",
                "alignment": "left",
                "type_preset": "h3",
                "font": "var(--font-body--family)",
                "font_size": "1.125rem",
                "color": "var(--color-foreground-heading)"
              }
            },
            "newsletter_text": {
              "type": "text",
              "settings": {
                "text": "<p>For exclusive offers & deals.</p>",
                "width": "100%",
                "alignment": "left",
                "type_preset": "paragraph",
                "font": "var(--font-body--family)",
                "font_size": "0.875rem",
                "color": "var(--color-foreground)"
              }
            },
            "email_signup": {
              "type": "email-signup",
              "settings": {
                "width": "fill",
                "display_type": "arrow",
                "label": "Subscribe",
                "integrated_button": true,
                "input_type_preset": "paragraph"
              }
            },
            "social_icons": {
              "type": "social-links",
              "settings": {
                "facebook_url": "https://facebook.com",
                "instagram_url": "https://instagram.com",
                "tiktok_url": "https://tiktok.com"
              }
            }
          },
          "block_order": [
            "newsletter_heading",
            "newsletter_text",
            "email_signup",
            "social_icons"
          ]
        },
        "col2_shop": {
          "type": "menu",
          "settings": {
            "menu": "main-menu",
            "heading": "Shop",
            "show_as_accordion": false,
            "inherit_color_scheme": false,
            "color_scheme": "scheme-4",
            "heading_preset": "h6",
            "link_preset": "paragraph"
          }
        },
        "col3_company": {
          "type": "menu",
          "settings": {
            "menu": "footer",
            "heading": "Company",
            "show_as_accordion": false,
            "inherit_color_scheme": false,
            "color_scheme": "scheme-4",
            "heading_preset": "h6",
            "link_preset": "paragraph"
          }
        }
      },
      "block_order": [
        "col1_newsletter",
        "col2_shop",
        "col3_company"
      ],
      "name": "Footer",
      "settings": {
        "section_width": "page-width",
        "gap": 48,
        "color_scheme": "scheme-4",
        "padding-block-start": 60,
        "padding-block-end": 60
      }
    },
    "footer_utilities": {
      "type": "footer-utilities",
      "blocks": {
        "copyright": {
          "type": "footer-copyright",
          "settings": {
            "show_powered_by": false,
            "font_size": "0.75rem"
          }
        },
        "policies": {
          "type": "footer-policy-list",
          "settings": {
            "font_size": "0.75rem"
          }
        },
        "payments": {
          "type": "payment-icons",
          "settings": {}
        }
      },
      "block_order": [
        "copyright",
        "policies",
        "payments"
      ],
      "name": "Utilities",
      "settings": {
        "section_width": "page-width",
        "gap": 24,
        "color_scheme": "scheme-4",
        "padding-block-start": 24,
        "padding-block-end": 48
      }
    }
  },
  "order": [
    "footer_main",
    "footer_utilities"
  ]
}
