{
  "sections": {
    "hero": {
      "type": "hero",
      "blocks": {
        "text": {
          "type": "text",
          "settings": {
            "text": "<h2>Lo Stile Italiano, a Casa Tua</h2><p>Esplora la nostra collezione premium di articoli per la casa, bellezza, accessori e regali. Vivi la dolce vita ogni giorno.</p>",
            "type_preset": "rte",
            "alignment": "center",
            "color": "var(--color-foreground-heading)"
          }
        },
        "button": {
          "type": "button",
          "settings": {
            "label": "Acquista Ora",
            "link": "shopify://collections/all",
            "style_class": "button-primary",
            "width": "fit-content"
          }
        }
      },
      "block_order": [
        "text",
        "button"
      ],
      "settings": {
        "color_scheme": "scheme-2",
        "horizontal_alignment_flex_direction_column": "center",
        "vertical_alignment_flex_direction_column": "center",
        "padding-block-start": 80,
        "padding-block-end": 80
      }
    },
    "categories": {
      "type": "multicolumn",
      "blocks": {
        "home": {
          "type": "column",
          "settings": {
            "title": "Casa e Cucina",
            "text": "<p>Eleganti accessori per la tua casa</p>"
          }
        },
        "beauty": {
          "type": "column",
          "settings": {
            "title": "Bellezza",
            "text": "<p>Cura della persona premium</p>"
          }
        },
        "accessories": {
          "type": "column",
          "settings": {
            "title": "Accessori",
            "text": "<p>Stile e dettagli unici</p>"
          }
        },
        "lifestyle": {
          "type": "column",
          "settings": {
            "title": "Stile di Vita",
            "text": "<p>Il meglio per la tua giornata</p>"
          }
        }
      },
      "block_order": [
        "home",
        "beauty",
        "accessories",
        "lifestyle"
      ],
      "settings": {
        "title": "Categorie Popolari",
        "color_scheme": "scheme-1",
        "columns_desktop": 4,
        "padding-block-start": 60,
        "padding-block-end": 60
      }
    },
    "featured_products": {
      "type": "product-list",
      "blocks": {
        "static-header": {
          "type": "_product-list-content",
          "static": true,
          "settings": {},
          "blocks": {
            "text": {
              "type": "_product-list-text",
              "settings": {
                "text": "<h3>Nuovi Arrivi</h3>",
                "type_preset": "h3"
              }
            }
          },
          "block_order": [
            "text"
          ]
        },
        "static-product-card": {
          "type": "_product-card",
          "static": true,
          "settings": {
            "border_radius": 16,
            "border": "solid",
            "border_color": "#F1F2F6",
            "border_width": 1
          },
          "blocks": {
            "gallery": {
              "type": "_product-card-gallery",
              "settings": {}
            },
            "title": {
              "type": "product-title",
              "settings": {
                "padding-block-start": 16
              }
            },
            "price": {
              "type": "price",
              "settings": {}
            },
            "add_to_cart": {
              "type": "add-to-cart-button",
              "settings": {
                "width": "fill"
              }
            }
          },
          "block_order": [
            "gallery",
            "title",
            "price",
            "add_to_cart"
          ]
        }
      },
      "settings": {
        "collection": "all",
        "layout_type": "grid",
        "columns": 4,
        "color_scheme": "scheme-1",
        "padding-block-start": 40,
        "padding-block-end": 40
      }
    },
    "promotions": {
      "type": "image-with-text",
      "blocks": {
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "Offerte Imperdibili",
            "heading_preset": "h2"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "<p>Scopri i nostri sconti esclusivi sui prodotti pi├╣ desiderati. Non perdere l'occasione di portare l'Italia a casa tua.</p>"
          }
        },
        "button": {
          "type": "button",
          "settings": {
            "label": "Scopri le Offerte",
            "link": "shopify://collections/all",
            "style_class": "button-primary"
          }
        }
      },
      "block_order": [
        "heading",
        "text",
        "button"
      ],
      "settings": {
        "color_scheme": "scheme-2",
        "desktop_image_width": "medium",
        "layout": "image_first",
        "desktop_content_position": "middle",
        "padding-block-start": 40,
        "padding-block-end": 40
      }
    },
    "trust": {
      "type": "multicolumn",
      "blocks": {
        "secure": {
          "type": "column",
          "settings": {
            "title": "Pagamenti Sicuri",
            "text": "<p>Transazioni protette al 100%</p>"
          }
        },
        "delivery": {
          "type": "column",
          "settings": {
            "title": "Spedizione Rapida",
            "text": "<p>Consegna veloce in tutta Italia</p>"
          }
        },
        "support": {
          "type": "column",
          "settings": {
            "title": "Assistenza Dedicata",
            "text": "<p>Supporto clienti sempre attivo</p>"
          }
        },
        "returns": {
          "type": "column",
          "settings": {
            "title": "Reso Facile",
            "text": "<p>30 giorni per restituire i tuoi acquisti</p>"
          }
        }
      },
      "block_order": [
        "secure",
        "delivery",
        "support",
        "returns"
      ],
      "settings": {
        "title": "Perch├⌐ Sceglierci",
        "color_scheme": "scheme-3",
        "columns_desktop": 4,
        "column_alignment": "center",
        "padding-block-start": 60,
        "padding-block-end": 60
      }
    },
    "newsletter": {
      "type": "newsletter",
      "blocks": {
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "Iscriviti alla Newsletter",
            "heading_preset": "h2"
          }
        },
        "paragraph": {
          "type": "paragraph",
          "settings": {
            "text": "<p>Ricevi aggiornamenti su nuovi arrivi e promozioni esclusive Xophia.</p>"
          }
        },
        "email_form": {
          "type": "email_form",
          "settings": {}
        }
      },
      "block_order": [
        "heading",
        "paragraph",
        "email_form"
      ],
      "settings": {
        "color_scheme": "scheme-2",
        "padding-block-start": 80,
        "padding-block-end": 80
      }
    }
  },
  "order": [
    "hero",
    "categories",
    "featured_products",
    "promotions",
    "trust",
    "newsletter"
  ]
}
